# ============================================================
# Harbour Island Insider — .gitignore
# ============================================================

# --- macOS junk ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Node (for any future tooling) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Environment secrets ---
.env
.env.local
.env.*.local

# --- Claude Code local settings (keep launch.json, ignore personal settings) ---
.claude/settings.local.json

# --- WordPress local dev artefacts (if you ever `npm run build` locally) ---
wordpress/child-theme/vendor/
wordpress/**/node_modules/
*.log

# --- Preview server caches ---
.cache/
.parcel-cache/
